APP_NAME=Kanokware
ENVIRONMENT=development
DATABASE_URL=sqlite:///./kanokware.db
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT_SECONDS=180
OPENAI_MAX_RETRIES=0
GENERATION_ATTEMPTS=2
GENERATION_STALE_MINUTES=8
ADMIN_KEY=replace-with-a-long-random-secret
MAX_UPLOAD_MB=15
MAX_CONTEXT_CHARS=60000
PASS_THRESHOLD=80
QUESTION_TIME_SECONDS=30
ALLOW_DEMO_QUESTIONS=true
SESSION_TOKEN_TTL_MINUTES=30
MAX_ATTEMPTS_PER_DOCUMENT=1

WEBCAM_REQUIRED=true
WEBCAM_MAX_IMAGE_KB=700

# Lecturer accounts and course access
LECTURER_SESSION_HOURS=12
AUTH_COOKIE_NAME=kanokware_lecturer_session
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15
LECTURER_REGISTRATION_ENABLED=false

# One-time lecturer setup code validity
ACCOUNT_SETUP_CODE_HOURS=48

# Assessment continuity and interruption recovery
HEARTBEAT_INTERVAL_SECONDS=5
HEARTBEAT_STALE_SECONDS=20
ASSESSMENT_RESUME_WINDOW_MINUTES=15
MAX_ASSESSMENT_INTERRUPTION_COUNT=2
MAX_ASSESSMENT_OFFLINE_SECONDS=300
