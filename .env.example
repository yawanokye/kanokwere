APP_NAME=Kanokwere
ENVIRONMENT=development
DATABASE_URL=sqlite:///./kanokwere.db
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT_SECONDS=180
OPENAI_MAX_RETRIES=0
GENERATION_ATTEMPTS=2
GENERATION_STALE_MINUTES=8
ADMIN_KEY=replace-with-a-long-random-secret
MAX_UPLOAD_MB=15
MAX_CONTEXT_CHARS=60000
PASS_THRESHOLD=80
QUESTION_TIME_SECONDS=30
ALLOW_DEMO_QUESTIONS=true
SESSION_TOKEN_TTL_MINUTES=30
MAX_ATTEMPTS_PER_DOCUMENT=1

WEBCAM_REQUIRED=true
WEBCAM_MAX_IMAGE_KB=700
